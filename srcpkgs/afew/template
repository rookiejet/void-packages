export SETUPTOOLS_SCM_PRETEND_VERSION="${version}"

post_build() {
	mkdir -p build/sphinx/man
	python3 -m sphinx -b man docs build/sphinx/man
}

post_install() {
	vlicense LICENSE
	vman build/sphinx/man/afew.1
}
