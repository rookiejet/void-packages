# temporarily track git till new release due to breakage with deprecated 'notmuch-python3'
_commit=bc09b1481d8b7e10f5bd90bae663664107e8552d
build_style=python3-pep517
hostmakedepends="python3-setuptools_scm python3-build python3-installer python3-Sphinx pkg-config"
depends="python3-notmuch2 python3-dkimpy python3-chardet python3-importlib_metadata notmuch"
